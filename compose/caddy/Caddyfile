# ===== VAULTWARDEN =====

vault.poppi {
    tls internal
    header {
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' wss://vault.poppi; frame-src 'none'; object-src 'none'"
    }

    reverse_proxy vaultwarden:80 {
        # Active les WebSockets (nécessaire pour Vaultwarden)
        transport http {
            websocket
        }
    }
}

===== PERSONNAL ERRORS (optionnel) =====

(handle_errors) {
    respond 404 "Not Found" 404
    respond 500 "Internal Server Error" 500
}